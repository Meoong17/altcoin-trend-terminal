# Altcoin Trend Terminal — Environment Variables
# Copy to .env and fill in.

# FRED API Key (Federal Reserve Economic Data)
# Used by liquidity/global_liquidity_engine.py and liquidity/repo_market_stress.py
# Both are shared macro modules — same key covers both.
# Get one free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# No key needed for altcoin/analyzer.py — uses Binance's public REST API,
# which works for any listed symbol without authentication.

# ── Multi-altcoin tracking ──
# Option 1: static list (used when TOP_N is unset and no --symbols flag)
# SYMBOLS=ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT
# Option 2: auto-discover top N altcoin USDT pairs by 24h volume
# (BTC excluded as benchmark; stablecoin pairs & leveraged tokens filtered out)
# TOP_N=20
# From networks where api.binance.com is blocked (many Indonesian ISPs):
# BINANCE_BASE=https://data-api.binance.vision
# Option 3: curated universe — 'l1' = own-chain Layer 1 coins only.
# Ranked by live 24h volume; delisted/renamed tickers auto-pruned.
# Combine with TOP_N to cap the count, e.g. GROUP=l1 + TOP_N=15
# GROUP=l1

# ── Fallback data source ──
# CoinStats Open API key (openapi.coinstats.app). Used ONLY when Binance
# fails for a coin: restores price metrics (RSI, momentum, vs-BTC ratio)
# but NOT volume history — affected cards are tagged in the dashboard.
# Free tier: 20k credits/month; fallback-only design keeps normal usage at 0.
# COINSTATS_API_KEY=your_key_here
# Bybit fallback tier (tier 3, keyless — no key needed). Override the
# base URL if api.bybit.com is blocked on your network:
# BYBIT_BASE=https://api.bybit.com

# ── News sentiment & catalyst layer (display-only) ──
# Free key: https://cryptopanic.com/developers/api/ — per-coin tagged news
# with community bullish/bearish votes. Without the key, layer is dormant.
# CRYPTOPANIC_API_KEY=your_key_here
# ── Breadth: track top-N market alts BEYOND the curated groups ──
# EXTEND_TOP=400

# ── Operational alerting (optional but recommended) ──
# Telegram bot for collector-failure and stale-data alerts. Create a bot
# via @BotFather, get your chat_id via @userinfobot or the getUpdates API.
# Without these, alerts are printed to stderr (still visible in cron logs).
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# STALE_ALERT_HOURS=8   # alert if the previous cycle's data is older than this

# OKX fallback tier (tier 2, keyless — no key needed for market data).
# Optional: a key may grant higher rate limits on paid tiers, not required.
# OKX_API_KEY=your_key_here
# OKX_BASE=https://www.okx.com
