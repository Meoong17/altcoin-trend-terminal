# secrets — never commit
.env

# per-cycle outputs (regenerated; data.json is deployed, not versioned)
data.json
collect.log
watchdog.log
*.pkl

# API caches
.backfill_cache/
.repo_stress_cache.json
.global_liquidity_cache.json
.fundamentals_cache.json

# local environment
.venv/
__pycache__/
*.pyc
.DS_Store

# local history.db backups (the rotation dir from the VPS tutorial)
backups/

# NOTE: history.db itself is deliberately NOT ignored — it's committed
# to the repo every cycle (see push_history.sh in the VPS deployment
# runbook) as an offsite backup of the training dataset.
.news_cache.json
.stablecoin_cache.json
